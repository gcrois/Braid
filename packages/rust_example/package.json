{
	"name": "@braid/rust_example",
	"version": "0.0.1",
	"main": "src/index.ts",
	"exports": {
		".": {
			"import": "./src/index.ts"
		},
		"./wasm": {
			"import": "./build/wasm/rust_example.js",
			"types": "./build/wasm/rust_example.d.ts"
		},
		"./native": {
			"require": "./target/release/rust_example"
		}
	},
	"type": "module",
	"scripts": {
		"test": "vitest run",
		"build:wasm": "wasm-pack build --target web",
		"build:nodejs": "wasm-pack build --target nodejs",
		"build:native": "cargo build --release",
		"build": "npm run build:wasm && npm run build:nodejs && npm run build:native",
		"run:native": "cargo run --release",
		"run:nodejs": "node ./src/run.js"
	},
	"devDependencies": {
		"typescript": "^5.7.2",
		"tsx": "^4.19.2",
		"vitest": "^2.1.6"
	},
	"dependencies": {
		"@braid/c_example": "workspace:*",
		"@types/node": "^22.10.1"
	}
}
